generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String      @id @default(uuid())
  email              String      @unique
  password           String
  isAdmin            Boolean     @default(false)
  isBanned           Boolean     @default(false)
  deviceId           String? 
  linkedInProfileId  String?     @unique
  subscriptionStatus String      @default("TRIAL") // TRIAL, ACTIVE, EXPIRED
  trialEndsAt        DateTime?
  subscriptionEndsAt DateTime?
  createdAt          DateTime    @default(now())
  
  settings   Settings?
  keywords   Keyword[]
  comments   Comment[]
  logs       Log[]
  autoPosts  AutoPost[]
  savedPosts SavedPost[]
  contactMessages ContactMessage[]
}

model Settings {
  id                    String  @id @default(uuid())
  maxCommentsPerDay     Int     @default(20)
  maxCommentsPerHour    Int     @default(5)
  maxCommentsPerWeek    Int     @default(100)
  maxProfileViewsPerDay Int     @default(100)
  minLikes              Int     @default(10)
  maxLikes              Int     @default(10000)
  minComments           Int     @default(2)
  maxComments           Int     @default(1000)
  minDelayMins          Int     @default(30)
  maxDelayMins          Int     @default(90)
  workHoursOnly         Boolean @default(true)
  workHoursStart        Int     @default(9)
  workHoursEnd          Int     @default(18)
  skipWeekends          Boolean @default(true)
  systemActive          Boolean @default(false)
  linkedinSessionCookie String  @default("")
  platformUrl           String  @default("")
  searchOnlyMode        Boolean @default(true)
  searchConfigJson      String  @default("[]")
  // Conservative search limits (safest configuration)
  maxSearchesPerHour    Int     @default(6)
  maxSearchesPerDay     Int     @default(20)
  minDelayBetweenSearchesMinutes Int @default(5)
  maxKeywordsPerCycle   Int     @default(3)
  
  // Cloud Proxy Configuration
  proxyHost             String?
  proxyPort             Int?
  proxyUser             String?
  proxyPass             String?
  
  // Extension Telemetry
  lastHeartbeat         DateTime?
  extensionStatus       String?
  
  userId                String  @unique
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Keyword {
  id          String   @id @default(uuid())
  keyword     String
  targetReach Int      @default(1000)
  targetCycles Int     @default(1)
  active      Boolean  @default(true)
  matches     Int      @default(0)
  createdAt   DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments    Comment[]
}

model Comment {
  id          String   @id @default(uuid())
  text        String
  category    String   @default("General")
  timesUsed   Int      @default(0)
  cycleIndex  Int      @default(1)
  createdAt   DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  keywordId   String?
  keyword     Keyword? @relation(fields: [keywordId], references: [id], onDelete: Cascade)
}

model Log {
  id         String   @id @default(uuid())
  action     String
  postUrl    String
  comment    String?
  commentUrl String?
  timestamp  DateTime @default(now())
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AutoPost {
  id        String   @id @default(uuid())
  topic     String
  content   String
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedPost {
  id          String   @id @default(uuid())
  postUrl     String
  postAuthor  String?
  postPreview String?
  likes       Int      @default(0)
  comments    Int      @default(0)
  keyword     String
  savedAt     DateTime @default(now())
  visited     Boolean  @default(false)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, savedAt])
  @@index([userId, keyword])
}

model PromoCode {
  id            String    @id @default(uuid())
  code          String    @unique
  discountType  String    @default("PERCENTAGE") // PERCENTAGE or FIXED (or ACTIVATION for 100% free)
  discountValue Float     @default(100)
  maxUses       Int       @default(1)
  currentUses   Int       @default(0)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  subject   String
  message   String
  status    String   @default("OPEN") // OPEN, REVIEWED, RESOLVED
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
