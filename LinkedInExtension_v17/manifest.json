{
  "manifest_version": 3,
  "name": "Nexora – LinkedIn AI Assistant",
  "version": "5.0",
  "version_name": "CDP-stable",
  "description": "Automated LinkedIn content scraper — CDP protocol-level extraction.",
  "permissions": [
    "storage", "alarms", "tabs", "scripting",
    "activeTab", "notifications", "cookies", "debugger"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "http://localhost:*/*",
    "https://*/*",
    "http://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js", "interceptor.js"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["dashboard-bridge.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon-48.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
