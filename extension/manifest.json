{
  "manifest_version": 3,
  "name": "Nexora – LinkedIn AI Assistant",
  "version": "8.3",
  "version_name": "Fix-404-Connection",
  "description": "Stable, deterministic LinkedIn content scraper. No CDP. Single execution context.",
  "permissions": [
    "storage", "alarms", "tabs", "scripting",
    "activeTab", "notifications", "cookies"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "http://localhost:*/*",
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon-48.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
