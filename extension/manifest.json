{
  "manifest_version": 3,
  "name": "Nexora – LinkedIn AI Assistant",
  "version": "8.0",
  "version_name": "Content-Script-Centric",
  "description": "Stable, deterministic LinkedIn content scraper. No CDP. Single execution context.",
  "permissions": [
    "storage", "alarms", "tabs", "scripting",
    "activeTab", "notifications", "cookies"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "http://localhost:*/*",
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [

    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["dashboard-bridge.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon-48.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
