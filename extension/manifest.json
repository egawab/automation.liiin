{
  "manifest_version": 3,
  "name": "LinkedIn Auto-Search Worker",
  "version": "1.1",
  "description": "Background worker for extracting LinkedIn posts securely from your browser.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
