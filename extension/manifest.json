{
  "manifest_version": 3,
  "name": "Nexora – LinkedIn AI Assistant",
  "version": "2.0",
  "description": "AI-powered LinkedIn engagement assistant. Auto-search, auto-comment with human-mimicry safety.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "http://localhost:*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
